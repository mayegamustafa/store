# ========================
# TotalStore Environment Variables
# Copy this to .env and fill in real values
# ========================

# ---- App ----
NODE_ENV=development
PORT=3001

# ---- Database ----
DATABASE_URL="postgresql://postgres:password@localhost:5432/totalstore_db"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- JWT ----
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- Africa's Talking (SMS / USSD) ----
AT_API_KEY="your-africas-talking-api-key"
AT_USERNAME="sandbox"
AT_SENDER_ID="TotalStore"

# ---- Firebase (Push Notifications) ----
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="your-firebase-private-key"
FIREBASE_CLIENT_EMAIL="your-firebase-client-email"

# ---- Pesapal ----
PESAPAL_CONSUMER_KEY="your-pesapal-consumer-key"
PESAPAL_CONSUMER_SECRET="your-pesapal-consumer-secret"
PESAPAL_API_URL="https://cybqa.pesapal.com/pesapalv3"
PESAPAL_IPN_URL="https://yourdomain.com/api/payments/ipn"

# ---- MTN Mobile Money (Uganda) ----
MTN_MOMO_BASE_URL="https://sandbox.momodeveloper.mtn.com"
MTN_MOMO_SUBSCRIPTION_KEY="your-mtn-subscription-key"
MTN_MOMO_API_USER="your-mtn-api-user"
MTN_MOMO_API_KEY="your-mtn-api-key"
MTN_MOMO_ENVIRONMENT="sandbox"
MTN_MOMO_CALLBACK_URL="https://yourdomain.com/api/payments/mtn/callback"

# ---- Airtel Money ----
AIRTEL_CLIENT_ID="your-airtel-client-id"
AIRTEL_CLIENT_SECRET="your-airtel-client-secret"
AIRTEL_BASE_URL="https://openapi.airtel.africa"
AIRTEL_CALLBACK_URL="https://yourdomain.com/api/payments/airtel/callback"

# ---- Flutterwave (future scaling) ----
FLUTTERWAVE_PUBLIC_KEY="your-flutterwave-public-key"
FLUTTERWAVE_SECRET_KEY="your-flutterwave-secret-key"
FLUTTERWAVE_ENCRYPTION_KEY="your-flutterwave-encryption-key"

# ---- Stripe (international) ----
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# ---- Google Maps ----
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ---- Cloud Storage (Cloudinary) ----
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ---- Email (SMTP) ----
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="TotalStore <noreply@totalstore.ug>"

# ---- Frontend URLs ----
WEB_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3002"
SELLER_URL="http://localhost:3003"
API_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3000,http://localhost:3002,http://localhost:3003"

# ---- Business Config ----
DEFAULT_COMMISSION_PERCENT=10
ESCROW_PERIOD_DAYS=3
CURRENCY="UGX"
COUNTRY_CODE="UG"
PLATFORM_NAME="TotalStore"
